#Figure 1-A

library(ggplot2)
library(dplyr)

df_A <- data.frame(
  Group = rep(c("AMD sediment", "Tailings"), each = 4),
  Phylum = rep(c("Proteobacteria", "Firmicutes", "Bacteroidetes", "Actinobacteria"), 2),
  Value = c(45.5, 31.8, 13.6, 9.1,
            80.8, 15.4, 3.8, 0)   
)

df_A <- df_A %>%
  group_by(Group) %>%
  arrange(desc(Phylum)) %>%
  mutate(
    fraction = Value / sum(Value),
    ymax = cumsum(fraction),
    ymin = lag(ymax, default = 0),
    label_pos = (ymax + ymin) / 2
  )

  pA <- ggplot(df_A, aes(ymax = ymax, ymin = ymin, xmax = 4, xmin = 2, fill = Phylum)) +
  geom_rect(color = "white") +
  geom_text(aes(x = 3, y = label_pos, label = paste0(Value, "%")), size = 4) +
  facet_wrap(~Group) +
  coord_polar(theta = "y") +
  xlim(0, 4) +
  theme_void() +
  theme(
    strip.text = element_text(size = 14, face = "bold"),
    legend.position = "bottom"
  )

pA


