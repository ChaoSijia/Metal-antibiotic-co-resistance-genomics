#(D)MGE
library(ggplot2)
library(dplyr)
library(tidyr)
library(ggbreak) 
library(scales)

data <- data.frame(
  type = c( "unit Tn","IS","IME","ICE","GI","composite Tn"),
  WK6 = c(0, 54, 0, 1, 12, 1, ),  
  WK16 = c(1, 72, 2, 1, 26, 2)  
)

plot_data <- data %>%
  pivot_longer(cols = c(WK6, WK16), names_to = "group", values_to = "value") %>%
  arrange(value) %>%
  mutate(type = factor(type, levels = unique(type)))


p <- ggplot(plot_data, aes(x = value, y = type, fill = group)) +
  geom_bar(stat = "identity", 
           position = position_dodge(width = 0.8),
           color = "black", 
           linewidth = 0.3, 
           width = 0.7) +

  geom_text(aes(label = value), 
            position = position_dodge(width = 0.8),
            hjust = -0.2, 
            size = 3, 
            color = "black") +

  scale_fill_manual(values = c("#4E79A7", "#F28E2B"), name = "Group") +
  labs(
    x = "Gene number", 
    y = "MGE type",
    title = "MGEs (WK6 vs WK16)"
  ) +
  theme_minimal(base_family = "Arial") +
  theme(
    plot.title = element_text(size = 14, face = "bold", hjust = 0.5),
    axis.title = element_text(size = 12),
    axis.text = element_text(size = 10, color = "black"),
    panel.grid.major.y = element_blank(),
    panel.grid.major.x = element_line(color = "grey80", linewidth = 0.2),
    legend.position = "top"
  )
  
p + 
  scale_x_continuous(expand = c(0, 0)) +
  scale_x_break(c(30, 50),  # 指定断裂区间
                scales = 0.5,  
                space = 0.1,   
                ticklabels = c(seq(0, 23, by = 5), seq(30, 40, by = 5))  
  )
